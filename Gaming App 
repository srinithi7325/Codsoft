import streamlit as st
import random
import numpy as np
import plotly.graph_objects as go
from collections import deque

# Title
st.set_page_config(page_title="RPS vs Smart AI", layout="wide")
st.title("Alex vs Smart AI")

# Initialize session state
if "history" not in st.session_state:
    st.session_state.history = []
if "player_wins" not in st.session_state:
    st.session_state.player_wins = st.session_state.ai_wins = st.session_state.ties = 0
if "player_moves" not in st.session_state:
    st.session_state.player_moves = deque(maxlen=10)

# Sidebar Scoreboard
with st.sidebar:
    st.header(f"Scoreboard - Alex")
    st.write(f"Your Wins: **{st.session_state.player_wins}**")
    st.write(f"AI Wins: **{st.session_state.ai_wins}**")
    st.write(f"Ties: **{st.session_state.ties}**")
    total = st.session_state.player_wins + st.session_state.ai_wins + st.session_state.ties
    win_rate = (st.session_state.player_wins / total * 100) if total > 0 else 0
    st.write(f"Win Rate: **{win_rate:.1f}%**")
    if st.button("Reset Game", use_container_width=True):
        for key in ["history", "player_wins", "ai_wins", "ties", "player_moves"]:
            st.session_state[key] = deque(maxlen=10) if "moves" in key else 0
        st.success("Game Reset!")

# Main game
col1, col2, col3 = st.columns(3)
move = None
if col1.button("Rock", use_container_width=True):
    move = "rock"
elif col2.button("Paper", use_container_width=True):
    move = "paper"
elif col3.button("Scissors", use_container_width=True):
    move = "scissors"

if move:
    # Smart AI Logic (simple pattern + random)
    if len(st.session_state.player_moves) >= 2:
        last_two = list(st.session_state.player_moves)[-2:]
        if last_two == ["rock", "paper"]:
            ai_move = "scissors"  
        elif last_two == ["paper", "scissors"]:
            ai_move = "rock"
        elif last_two == ["scissors", "rock"]:
            ai_move = "paper"
        else:
            ai_move = random.choice(["rock", "paper", "scissors"])
    else:
        ai_move = random.choice(["rock", "paper", "scissors"])
    
    st.session_state.player_moves.append(move)
    
    # Determine winner
    result = ""
    if move == ai_move:
        result = "Tie!"
        st.session_state.ties += 1
    elif (move == "rock" and ai_move == "scissors") or \
         (move == "paper" and ai_move == "rock") or \
         (move == "scissors" and ai_move == "paper"):
        result = "You Win!"
        st.session_state.player_wins += 1
    else:
        result = "AI Wins!"
        st.session_state.ai_wins += 1
    
    st.session_state.history.append((move, ai_move, result))

# Display latest result
if st.session_state.history:
    player, ai, res = st.session_state.history[-1]
    emoji = {"rock":"Rock", "paper":"Paper", "scissors":"Scissors"}
    color = "green" if "You Win" in res else "red" if "AI Wins" in res else "gray"
    st.markdown(f"### <span style='color:{color}'>{res}</span>", unsafe_allow_html=True)
    st.write(f"You: {emoji[player]} **{player.capitalize()}** vs AI: {emoji[ai]} **{ai.capitalize()}**")

# Move Pattern Chart
if len(st.session_state.player_moves) > 1:
    moves_num = [0 if m=="rock" else 1 if m=="paper" else 2 for m in st.session_state.player_moves]
    fig = go.Figure(data=go.Scatter(y=moves_num, mode='lines+markers', name='Your Moves'))
    fig.update_layout(title="Your Move Pattern (0=Rock, 1=Paper, 2=Scissors)",
                      xaxis_title="Round", yaxis=dict(tickmode='array', tickvals=[0,1,2], ticktext=['Rock','Paper','Scissors']))
    st.plotly_chart(fig, use_container_width=True)

st.caption("Built with Streamlit + scikit-learn • Be unpredictable!")